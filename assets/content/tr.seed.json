  "education.feature.heading.title.001": {
    "type": "text",
    "value": "Ukraynalı Öğrenciler için Türkiye Üniversiteleri"
  },
  "education.feature.intro.001": {
    "type": "text",
    "value": "Ukraynalı öğrenciler Türkiye'deki devlet ve vakıf üniversitelerine başvurabilir. Savaş döneminde özel kolaylıklar tanınmıştır."
  },
  "education.h3.001": {
    "type": "text",
    "value": "YÖK Denklik İşlemi"
  },
  "education.h3.002": {
    "type": "text",
    "value": "Türk Öğrenciler için Ukrayna Üniversiteleri"
  },
  "education.highlight.box.001": {
    "type": "html",
    "value": "<strong>Türkiye Bursları (YTB):</strong> Her yıl yabancı öğrencilere burs verilir. Burs kapsamı: aylık burs + yurt + sağlık sigortası + Türkçe dil kursu. Başvuru: <strong>turkiyeburslari.gov.tr</strong>"
  },
  "education.highlight.box.002": {
    "type": "html",
    "value": "Uyarı: <strong>Savaş Nedeniyle Önemli Uyarı:</strong> Ukrayna'daki kurumlarla iletişim kurmanın güç olduğu durumlarda belge temininde gecikmeler yaşanabilir. Sürecinizi hızlandırmak için <strong>YÖK'ü doğrudan Türkiye'den aramanız</strong> önerilir.<br><br>\n        \n        <strong>YÖK Denklik Birimi:</strong>  <a class=\"content-link\" href=\"tel:+903122982000\">+90 (312) 298 20 00</a><br>\n        \n        <a class=\"content-link\" href=\"https://denklik.yok.gov.tr\" target=\"_blank\">denklik.yok.gov.tr</a>"
  },
  "education.highlight.box.003": {
    "type": "html",
    "value": "Uyarı: <strong>Dikkat:</strong> Savaş nedeniyle bazı şehirlerde eğitim sekteye uğrayabilir. Başvurmadan önce üniversitenin güncel durumunu kontrol edin."
  },
  "education.p.001": {
    "type": "text",
    "value": "Ukrayna'da alınan diplomaların Türkiye'de tanınması için YÖK'e denklik başvurusu yapılmalıdır."
  },
  "education.p.002": {
    "type": "text",
    "value": "Ukrayna'daki üniversiteler Türk öğrencilere düşük maliyetli tıp, mühendislik ve hukuk eğitimi sunmaktadır."
  },
  "education.section.sub.001": {
    "type": "text",
    "value": "Ukraynalı öğrenciler için Türk üniversitelerine başvuru rehberi ve Türk öğrenciler için Ukrayna üniversiteleri hakkında kapsamlı bilgi."
  },
  "education.section.title.001": {
    "type": "html",
    "value": "Türkiye & Ukrayna<br>Üniversite İşlemleri"
  },
  "education.span.001": {
    "type": "text",
    "value": "ÜNİVERSİTE REHBERİ"
  },
  "education.span.002": {
    "type": "text",
    "value": "Diploma + transkript Apostil onaylı olmalı"
  },
  "education.span.003": {
    "type": "text",
    "value": "Yeminli tercüman ile Türkçe'ye çevir"
  },
  "education.span.004": {
    "type": "text",
    "value": "denklik.yok.gov.tr üzerinden e-başvuru"
  },
  "education.span.005": {
    "type": "text",
    "value": "Tıp/diş/eczacılık için STS sınavı zorunlu"
  },
  "education.span.006": {
    "type": "text",
    "value": "90 güne kadar vizesiz giriş (çipli kimlik yeterli)"
  },
  "education.span.007": {
    "type": "text",
    "value": "Üniversiteye kabul mektubunu al"
  },
  "education.span.008": {
    "type": "text",
    "value": "90 gün sonrası için D tipi öğrenci vizesi başvur"
  },
  "education.span.009": {
    "type": "text",
    "value": "Türkiye'ye döndükten sonra YÖK denklik başvurusu yap"
  },
  "education.step.list.001": {
    "type": "html",
    "value": "<li><span class=\"step-num\">1</span>YÖK Atlas veya üniversite web sitesinden program seç</li>\n          \n          <li><span class=\"step-num\">2</span>Lise/üniversite transkriptini Türkçe'ye tercüme ettir ve noter onaylat</li>\n          \n          <li><span class=\"step-num\">3</span>YÖS sınavına gir (devlet üniv.) veya üniversite sınavına başvur</li>\n          \n          <li><span class=\"step-num\">4</span>Kabul mektubu al, öğrenci vizesi başvurusu yap</li>\n          \n          <li><span class=\"step-num\">5</span>Türkiye'ye geldikten sonra İkamet İzni başvurusu yap</li>"
  },
